# ──────────────────────────────────────────────────────────────────────────
# Acolhe.animal — environment variables
# Copy to `.env` (and/or `apps/web/.env.local`) and fill in.
# For local development with mocked integrations, the defaults below work as-is
# once Postgres is running (see `pnpm db:up`).
# ──────────────────────────────────────────────────────────────────────────

# ── Core ───────────────────────────────────────────────────────────────────
NODE_ENV=development
# Public base URL of the app (used for absolute links, OG tags, auth callbacks).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Postgres) ──────────────────────────────────────────────────────
# Local Docker default (see packages/db/docker-compose.yml). Swap for the Neon
# connection string in production.
DATABASE_URL=postgresql://acolhe:acolhe@localhost:5432/acolhe_animal

# ── Auth (better-auth) ───────────────────────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=dev-only-insecure-secret-change-me-please-32+chars
BETTER_AUTH_URL=http://localhost:3000

# ── Integrations switch ──────────────────────────────────────────────────────
# `mock`  → all external providers are stubbed (no network, no accounts needed).
# `live`  → real adapters; requires the provider credentials below.
INTEGRATIONS_MODE=mock

# ── Asaas (payments / BaaS subaccounts) — only needed when INTEGRATIONS_MODE=live
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_SECRET=
MASTER_WALLET_ID=
# AES-256-GCM master key for encrypting org Asaas API keys (32 bytes, base64).
ASAAS_KEY_ENCRYPTION_SECRET=dev-only-insecure-32-byte-key-base64==
# Separate master key for encrypting payout account secrets (defense in depth).
PAYOUT_ENCRYPTION_SECRET=dev-only-insecure-32-byte-key-base64-2==

# ── Cloudflare R2 (file storage) — only needed when INTEGRATIONS_MODE=live
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=acolhe-animal
# Public base URL that serves objects from the bucket.
R2_PUBLIC_URL=http://localhost:3000/local-storage

# ── Resend (email) — only needed when INTEGRATIONS_MODE=live
RESEND_API_KEY=
EMAIL_FROM=Acolhe.animal <nao-responda@acolhe.animal>

# ── Evolution API (WhatsApp) — only needed when INTEGRATIONS_MODE=live
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=acolhe-animal
