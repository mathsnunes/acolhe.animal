# Install peer deps automatically (Next/React ecosystem expects this).
auto-install-peers=true

# Do not fail install on peer mismatch — warn instead. Keeps the MVP unblocked
# while the ecosystem stabilizes around React 19 / Tailwind 4.
strict-peer-dependencies=false

# Hoist nothing by default (pnpm's isolated node_modules) — keeps imports honest.
# Public hoist pattern only for tooling that scans the root node_modules.
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*eslint*
